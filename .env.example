# ============================================================
# Attorney.AI — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── LLM Provider ─────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_CHAT_MODEL=gpt-4o-mini

# Alternative: Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# ── Vector Database (Qdrant) ──────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                      # Only needed for Qdrant Cloud
QDRANT_COLLECTION=attorney_ai_legal

# ── Legal Data APIs ───────────────────────────────────────
# CourtListener — register at https://www.courtlistener.com/sign-in/
COURTLISTENER_API_KEY=

# GovInfo — register at https://api.govinfo.gov/
GOVINFO_API_KEY=

# Federal Register — no key needed (public)
# eCFR — no key needed (public)
# SEC EDGAR — no key needed (public)

# ── App Configuration ─────────────────────────────────────
APP_ENV=development                  # development | production
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=INFO

# ── RAG Configuration ─────────────────────────────────────
CHUNK_SIZE=512                       # tokens per chunk
CHUNK_OVERLAP=64                     # token overlap between chunks
TOP_K_RETRIEVE=20                    # candidates before reranking
TOP_K_RERANK=5                       # final chunks sent to generator
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2

# ── Frontend ──────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000

# ── Elasticsearch (optional, for BM25) ───────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=attorney_ai_bm25

# ── Evaluation ────────────────────────────────────────────
LEGALBENCH_RAG_PATH=./data/legalbench_rag
