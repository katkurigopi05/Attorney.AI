# ============================================================
# Attorney.AI — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Ollama (LOCAL LLM — FREE, no API key needed) ─────────────────────────────
# Install: https://ollama.com   then run: ollama pull llama3.1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
# Other free options: mistral | phi3:mini | qwen2.5:7b | gemma2:9b

# ── Supabase (VECTOR DB — FREE tier) ─────────────────────────────────────────
# 1. Create free project at https://supabase.com
# 2. Run supabase_setup.sql in your project's SQL Editor
# 3. Get URL + service_role key from: Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_TABLE=legal_chunks

# ── Embeddings (LOCAL — FREE, uses sentence-transformers) ────────────────────
EMBEDDING_BACKEND=local
LOCAL_EMBEDDING_MODEL=bge-large
# Options: bge-large (1024-dim) | bge-small (384-dim) | legal-bert (768-dim) | minilm (384-dim)
# ⚠️ If you change the model, update vector(1024) in supabase_setup.sql to match the new dim
EMBEDDING_DIM=1024

# ── OpenAI (OPTIONAL — only needed if you want OpenAI instead of Ollama) ─────
# Leave blank to use Ollama. If set, OpenAI takes priority automatically.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_CHAT_MODEL=gpt-4o-mini

# ── Legal Data APIs (mostly FREE, no keys required) ──────────────────────────
# CourtListener: unauthenticated = 10 req/day. Register for higher limits:
# https://www.courtlistener.com/sign-in/
COURTLISTENER_API_KEY=

# GovInfo: most endpoints open without key. Optional key for higher limits:
# https://api.govinfo.gov/
GOVINFO_API_KEY=

# eCFR, Federal Register, SEC EDGAR → no key needed (fully public)

# ── HuggingFace Transformer Models (all FREE, auto-downloaded on first run) ──
NER_MODEL=dslim/bert-base-NER
NLI_MODEL=cross-encoder/nli-deberta-v3-base
SUMMARIZER_MODEL=nsi319/legal-led-base-16384
CLASSIFIER_MODEL=facebook/bart-large-mnli
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=INFO
